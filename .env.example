# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=false

# ─── Database (local Docker) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://investingbuddy:investingbuddy@localhost:5432/investingbuddy

# ─── Azure OpenAI ──────────────────────────────────────────────────────────────
# Leave empty for local development without agent workflows.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# ─── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=investingbuddy-documents

# ─── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=investingbuddy-research

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─── Financial Data Provider (Phase 4) ────────────────────────────────────────
# Select provider: mock | eodhd | sec_edgar | stooq | openbb | gleif
# Default is "mock" — CI and local development work with no credentials.
FINANCIAL_DATA_PROVIDER=mock

# EODHD credentials — required only when FINANCIAL_DATA_PROVIDER=eodhd.
# Never hardcode. Store in Azure Key Vault for staging/production.
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com/api

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Not yet wired in Phase 1. Add when authentication is implemented.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
