# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=false

# ─── Database (local Docker) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://investingbuddy:investingbuddy@localhost:5432/investingbuddy

# ─── LLM Provider (Phase 7) ───────────────────────────────────────────────────
# Select LLM client: mock (default, no credentials) | azure_openai
# Default is "mock" — CI and local development require no Azure credentials.
LLM_PROVIDER=mock

# ─── Azure OpenAI ──────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=azure_openai.
# Staging resource: ib-stg-openai (westeurope, S0). Model: gpt-4.1-mini v2025-04-14.
# Never hardcode real keys. Store in Azure Key Vault (ib-stg-kv) for staging/production.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# ─── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=investingbuddy-documents

# ─── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=investingbuddy-research

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─── Financial Data Provider (Phase 4) ────────────────────────────────────────
# Select provider: mock | eodhd | sec_edgar | stooq | openbb | gleif
# Default is "mock" — CI and local development work with no credentials.
FINANCIAL_DATA_PROVIDER=mock

# EODHD credentials — required only when FINANCIAL_DATA_PROVIDER=eodhd.
# Never hardcode. Store in Azure Key Vault for staging/production.
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com/api

# ─── Live Provider Integration Tests (Phase 5) ────────────────────────────────
# Set to true ONLY for local manual integration testing with live network.
# Leave false (or unset) in CI — CI must always run offline.
ENABLE_INTEGRATION_TESTS=false

# ─── EODHD Live Integration Tests (Phase 13) ──────────────────────────────────
# Set to true ONLY for local manual testing with a real EODHD_API_KEY.
# Requires EODHD_API_KEY to be set. Never set in CI.
ENABLE_EODHD_INTEGRATION_TESTS=false

# ─── Staging Access Control (Phase 12) ────────────────────────────────────────
# Protects the staging API with HTTP Basic Auth when APP_ENV=staging.
# Format: "username:password" — leave empty in local development.
# Store in Azure Key Vault (ib-stg-kv) as 'staging-basic-auth' for staging.
# Never set this in production — use proper authentication (Clerk/Entra).
STAGING_BASIC_AUTH=

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Not yet wired in Phase 1. Add when authentication is implemented.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
